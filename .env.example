# ─────────────────────────────────────────────
# Blockchain Service — Environment Variables
# ─────────────────────────────────────────────

# PostgreSQL
DATABASE_URL="postgresql+asyncpg://postgres:yourpassword@localhost:5432/blockchain_db"

# Server
PORT=8000
HOST=0.0.0.0
NODE_ENV=production

# Service identity (observability)
SERVICE_NAME=blockchain-service
SERVICE_VERSION=1.0.0

# OpenTelemetry — OTLP endpoint (Alloy/Collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
